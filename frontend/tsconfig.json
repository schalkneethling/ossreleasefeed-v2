{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ES2022",
    "types": ["vite/client"],
    "useDefineForClassFields": true
  },
  "include": ["src", "vite.config.ts"]
}
