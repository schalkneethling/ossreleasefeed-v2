# Security headers for the Cloudflare Pages-served SPA. The Worker's own
# header middleware only covers Worker responses, not these static pages.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://analytics.schalkneethling.com; connect-src 'self' https://ossreleasefeed-worker.volume4-schalk.workers.dev https://analytics.schalkneethling.com; img-src 'self' data:; font-src 'self'; style-src 'self'; frame-ancestors 'none'; base-uri 'self'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains
