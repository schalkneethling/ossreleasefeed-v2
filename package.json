{
  "name": "ossreleasefeed-v2",
  "private": true,
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:worker": "varlock run -- pnpm --filter worker dev",
    "build:frontend": "pnpm --filter frontend build",
    "build:worker": "pnpm --filter worker build",
    "build": "pnpm run build:frontend && pnpm run build:worker",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.json && tsc --noEmit -p worker/tsconfig.json",
    "lint": "oxlint . && stylelint \"frontend/src/**/*.css\" && pnpm run format:check",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@cloudflare/workers-types": "^4.20260214.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "@varlock/1password-plugin": "^2.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "effect": "^3.19.19",
    "msw": "^2.10.5",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.14.0",
    "playwright": "^1.56.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-logical-css": "^2.1.0",
    "stylelint-plugin-use-baseline": "*",
    "stylelint-selector-bem-pattern": "^4.0.1",
    "typescript": "^5.9.3",
    "varlock": "^1.10.0",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.9.0"
}
