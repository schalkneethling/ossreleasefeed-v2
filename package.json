{
  "name": "ossreleasefeed-v2",
  "private": true,
  "workspaces": [
    "frontend",
    "worker"
  ],
  "scripts": {
    "dev:frontend": "bun --filter frontend dev",
    "dev:worker": "bun --filter worker dev",
    "build:frontend": "bun --filter frontend build",
    "build:worker": "bun --filter worker build",
    "build": "bun run build:frontend && bun run build:worker",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.json && tsc --noEmit -p worker/tsconfig.json",
    "lint": "oxlint . && stylelint \"frontend/src/**/*.css\" && bun run format:check",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test": "bun run test:unit && bun run test:integration",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@cloudflare/workers-types": "^4.20260214.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "msw": "^2.10.5",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.14.0",
    "playwright": "^1.56.1",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.0",
    "stylelint-plugin-logical-css": "^1.2.3",
    "stylelint-plugin-use-baseline": "*",
    "stylelint-selector-bem-pattern": "^4.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "bun@1.2.22"
}
